# --- GLOBALNE POSTAVKE ---
NODE_ENV=development

# --- PORT SERVISA (Da se ne bi sudarali lokalno) ---
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
POST_SERVICE_PORT=8003
INTERACTION_SERVICE_PORT=8004
SOCIAL_SERVICE_PORT=8005
FEED_SERVICE_PORT=8006

# --- ZAJEDNICKA MYSQL PODESAVANJA ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=admin

# --- PO SERVISU BAZA / OVERRIDE VREDNOSTI ---
AUTH_DB_HOST=localhost
AUTH_DB_PORT=3306
AUTH_DB_USER=root
AUTH_DB_PASSWORD=admin
AUTH_DB_NAME=auth_db

USER_DB_HOST=localhost
USER_DB_PORT=3306
USER_DB_USER=root
USER_DB_PASSWORD=admin
USER_DB_NAME=user_db

POST_DB_HOST=localhost
POST_DB_PORT=3306
POST_DB_USER=root
POST_DB_PASSWORD=admin
POST_DB_NAME=post_db

INTERACTION_DB_HOST=localhost
INTERACTION_DB_PORT=3306
INTERACTION_DB_USER=root
INTERACTION_DB_PASSWORD=admin
INTERACTION_DB_NAME=interaction_db

SOCIAL_DB_HOST=localhost
SOCIAL_DB_PORT=3306
SOCIAL_DB_USER=root
SOCIAL_DB_PASSWORD=admin
SOCIAL_DB_NAME=social_db

FEED_DB_HOST=localhost
FEED_DB_PORT=3306
FEED_DB_USER=root
FEED_DB_PASSWORD=admin
FEED_DB_NAME=feed_db

# --- LEGACY URL VARIJANTE (ako neko koristi connection string pristup) ---
AUTH_DB_URL=mysql://root:admin@localhost:3306/auth_db
USER_DB_URL=mysql://root:admin@localhost:3306/user_db
POST_DB_URL=mysql://root:admin@localhost:3306/post_db
INTERACTION_DB_URL=mysql://root:admin@localhost:3306/interaction_db
SOCIAL_DB_URL=mysql://root:admin@localhost:3306/social_db
FEED_DB_URL=mysql://root:admin@localhost:3306/feed_db

# --- URL-OVI SERVISA ZA MEDJUSOBNU KOMUNIKACIJU ---
API_GATEWAY_URL=http://localhost:8000
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
POST_SERVICE_URL=http://localhost:8003
INTERACTION_SERVICE_URL=http://localhost:8004
SOCIAL_SERVICE_URL=http://localhost:8005
FEED_SERVICE_URL=http://localhost:8006

# --- REDIS (opciono za feed cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT / AUTENTIFIKACIJA ---
JWT_SECRET=promeni_me_u_produkciji
JWT_PUBLIC_KEY=putanja_ili_sadrzaj_public_kljuca
JWT_PRIVATE_KEY=putanja_ili_sadrzaj_private_kljuca
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# --- POST SERVICE ---
MAX_FILE_SIZE=52428800
